<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:id="rootPane"
            fx:controller="dev.m1le.mjrmanager.MainController"
            styleClass="main-container">

    <top>
        <VBox>
            <MenuBar styleClass="menu-bar">
                <Menu text="Файл">
                    <MenuItem text="Открыть JAR..." onAction="#onOpenJar" accelerator="Ctrl+O"/>
                    <Menu fx:id="menuRecent" text="Последние файлы"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Сохранить JAR" onAction="#onSaveJar" accelerator="Ctrl+S"/>
                    <MenuItem text="Сохранить как..." onAction="#onSaveAs" accelerator="Ctrl+Shift+S"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Выход" onAction="#onExit"/>
                </Menu>
                <Menu text="Редактор">
                    <MenuItem text="Скомпилировать класс" onAction="#onCompileCurrentTab" accelerator="Ctrl+Shift+C"/>
                    <SeparatorMenuItem/>
                    <Menu text="Компилятор">
                        <RadioMenuItem fx:id="menuCompilerEclipse" text="Eclipse JDT (мягкий, с ошибками)" onAction="#onSelectCompilerEclipse" selected="true"/>
                        <RadioMenuItem fx:id="menuCompilerJavac" text="javac (строгий)" onAction="#onSelectCompilerJavac"/>
                    </Menu>
                </Menu>
                <Menu text="Справка">
                    <MenuItem text="О программе" onAction="#onAbout"/>
                </Menu>
            </MenuBar>

            <ToolBar styleClass="main-toolbar">
                <Button fx:id="btnOpenJar" onAction="#onOpenJar" styleClass="button-icon">
                    <graphic><FontIcon iconLiteral="mdi2f-folder-open" iconSize="18"/></graphic>
                    <tooltip><Tooltip text="Открыть JAR (Ctrl+O)"/></tooltip>
                </Button>
                <Button fx:id="btnSaveJar" onAction="#onSaveJar" styleClass="button-icon">
                    <graphic><FontIcon iconLiteral="mdi2c-content-save" iconSize="18"/></graphic>
                    <tooltip><Tooltip text="Сохранить JAR (Ctrl+S)"/></tooltip>
                </Button>
                <Button fx:id="btnSaveAs" onAction="#onSaveAs" styleClass="button-icon">
                    <graphic><FontIcon iconLiteral="mdi2c-content-save-edit" iconSize="18"/></graphic>
                    <tooltip><Tooltip text="Сохранить как..."/></tooltip>
                </Button>
                <Separator/>
                <Button fx:id="btnCompile" onAction="#onCompileCurrentTab" styleClass="button-icon, button-compile">
                    <graphic><FontIcon iconLiteral="mdi2p-play-circle" iconSize="18"/></graphic>
                    <tooltip><Tooltip text="Скомпилировать (Ctrl+Shift+C)"/></tooltip>
                </Button>
                <Separator/>
                <TextField fx:id="searchField" promptText="Поиск класса..." prefWidth="200"
                           onAction="#onSearch"/>
                <Button fx:id="btnSearch" onAction="#onSearch" styleClass="button-icon">
                    <graphic><FontIcon iconLiteral="mdi2m-magnify" iconSize="18"/></graphic>
                </Button>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="jarNameLabel" styleClass="jar-name-label" text="Нет открытого файла"/>
            </ToolBar>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.25" styleClass="main-split" fx:id="mainSplit">
            <VBox styleClass="sidebar" minWidth="200" prefWidth="280">
                <Label text="Структура JAR" styleClass="sidebar-header"/>
                <TreeView fx:id="fileTree" VBox.vgrow="ALWAYS" styleClass="file-tree"/>
            </VBox>

            <StackPane VBox.vgrow="ALWAYS">
                <VBox fx:id="welcomePane" alignment="CENTER" spacing="20" styleClass="welcome-pane">
                    <FontIcon iconLiteral="mdi2a-archive" iconSize="80" styleClass="welcome-icon"/>
                    <Label text="MJRManager" styleClass="welcome-title"/>
                    <Label text="JAR Decompiler &amp; Editor" styleClass="welcome-subtitle"/>
                    <Button text="Открыть JAR файл" onAction="#onOpenJar"
                            styleClass="button-accent" prefWidth="200"/>
                </VBox>
                <TabPane fx:id="editorTabPane" styleClass="editor-tabs"/>
            </StackPane>
        </SplitPane>
    </center>

    <bottom>
        <HBox fx:id="statusBar" styleClass="status-bar" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets left="10" right="10" top="4" bottom="4"/></padding>
            <ProgressBar fx:id="progressBar" prefWidth="120" prefHeight="12"
                         visible="false" styleClass="status-progress"/>
            <Label fx:id="statusLabel" text="Готов" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#onToggleConsole" styleClass="console-toggle-button">
                <graphic><FontIcon iconLiteral="mdi2c-console" iconSize="16"/></graphic>
                <tooltip><Tooltip text="Консоль отладки"/></tooltip>
            </Button>
        </HBox>
    </bottom>

</BorderPane>
